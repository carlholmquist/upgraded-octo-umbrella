---
interface Props {
  title: string;
  pageLabel?: string;
  back?: boolean;
  backHref?: string;
  backLabel?: string;
  centerMain?: boolean;
  showClock?: boolean;
  fullBleed?: boolean;
}

const {
  title,
  pageLabel,
  back = false,
  backHref = "/",
  backLabel = "← holmquist.studio",
  centerMain = false,
  showClock = false,
  fullBleed = false,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      const themes = [
        { bg: "#0c1a12", text: "168, 230, 190" },
        { bg: "#16191b", text: "226, 230, 232" },
        { bg: "#0a1520", text: "125, 211, 252" },
        { bg: "#1a0e1f", text: "216, 180, 254" },
        { bg: "#1a0f08", text: "253, 186, 116" },
      ];
      const t = themes[Math.floor(Math.random() * themes.length)];
      document.documentElement.style.setProperty("--bg", t.bg);
      document.documentElement.style.setProperty("--text", `rgb(${t.text})`);
      document.documentElement.style.setProperty("--text-dim", `rgba(${t.text}, 0.35)`);
      document.documentElement.style.setProperty("--text-mid", `rgba(${t.text}, 0.65)`);
      document.documentElement.style.background = t.bg;
    </script>
  </head>
  <body>

    <header id="site-header">
      {back
        ? <a href={backHref} class="back-link">{backLabel}</a>
        : <span class="header-left"><slot name="header-left" /></span>
      }
      <span class="header-right">
        {showClock
          ? <span class="clock-wrap"><span id="clock">--:--</span><span id="date" class="date-dim"></span></span>
          : pageLabel
        }
      </span>
    </header>

    <main class:list={[{ center: centerMain, "full-bleed": fullBleed }]}>
      <slot />
    </main>

    <footer id="site-footer">
      <span class="footer-left"><slot name="footer-left" /></span>
      <span class="footer-right"><slot name="footer-right" /></span>
    </footer>

  </body>
</html>


{showClock && (
  <script>
    function updateClock() {
      const now = new Date();
      const time = now.toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: false });
      const date = now.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" });
      const c = document.getElementById("clock");
      const d = document.getElementById("date");
      if (c) c.textContent = time;
      if (d) d.textContent = date;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
)}

<style>
  :root {
    --bg: #0c1a12;
    --text: #a8e6be;
    --text-dim: rgba(168, 230, 190, 0.35);
    --text-mid: rgba(168, 230, 190, 0.65);
    --header-h: 60px;
    --footer-h: 50px;
  }


  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    line-height: 1.75;
    min-height: 100vh;
  }

  #site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid rgba(226, 230, 232, 0.06);
  }

  .back-link {
    font-size: 100%;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: color 275ms;
  }
  .back-link:hover { color: var(--text); }

  .header-left, .header-right {
    font-size: 100%;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  .clock-wrap {
    display: flex;
    gap: 16px;
    color: var(--text-mid);
    letter-spacing: 0.05em;
  }

  .date-dim { opacity: 0.5; }

  main {
    padding: calc(var(--header-h) + 48px) 24px calc(var(--footer-h) + 48px);
    max-width: 760px;
    margin: 0 auto;
  }

  main.full-bleed {
    padding: var(--header-h) 0 var(--footer-h);
    max-width: none;
  }

  main.center {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    gap: 40px;
  }

  #site-footer {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: var(--footer-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    background: var(--bg);
    border-top: 1px solid rgba(226, 230, 232, 0.06);
  }

  .footer-left, .footer-right {
    font-size: 100%;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    display: flex;
    gap: 24px;
  }

  /* Shared link style for pages to use */
  :global(.dark-link) {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 300ms;
  }
  :global(.dark-link:hover) { color: var(--text); }

  /* Shared section label */
  :global(.section-label) {
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-bottom: 20px;
  }

  /* Shared animated underline link */
  :global(.nav-link) {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 28px;
    text-decoration: none;
    color: var(--text);
    position: relative;
    transition: color 275ms;
  }
  :global(.nav-link::after) {
    content: '';
    position: absolute;
    bottom: 1px;
    left: 0; width: 100%; height: 1px;
    background: var(--text);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 275ms cubic-bezier(0.86, 0, 0.07, 1);
  }
  :global(.nav-link:hover::after) {
    transform: scaleX(1);
    transform-origin: left;
  }
  :global(.nav-link .nav-index) {
    font-size: 100%;
    opacity: 0.45;
    transition: opacity 275ms;
    flex-shrink: 0;
    width: 28px;
  }
  :global(.nav-link:hover .nav-index) { opacity: 0.75; }
  :global(.nav-link .nav-label) {
    font-size: 100%;
    font-weight: 300;
    letter-spacing: 0.04em;
  }
</style>
