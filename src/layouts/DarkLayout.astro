---
interface Props {
  title: string;
  pageLabel?: string;
  back?: boolean;
  backHref?: string;
  backLabel?: string;
  centerMain?: boolean;
  showClock?: boolean;
  fullBleed?: boolean;
  fixedTheme?: { bg: string; text: string };
}

const {
  title,
  pageLabel,
  back = false,
  backHref = "/",
  backLabel = "← holmquist.studio",
  centerMain = false,
  showClock = false,
  fullBleed = false,
  fixedTheme,
} = Astro.props;

const fixedThemeJson = fixedTheme ? JSON.stringify(fixedTheme) : "null";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <slot name="head" />
    <script is:inline define:vars={{ fixedThemeJson }}>
      const fixedTheme = JSON.parse(fixedThemeJson);
      const themes = [
        { bg: "#0c1a12", text: "168, 230, 190" },
        { bg: "#16191b", text: "226, 230, 232" },
        { bg: "#0a1520", text: "125, 211, 252" },
        { bg: "#1a0e1f", text: "216, 180, 254" },
        { bg: "#1a0f08", text: "253, 186, 116" },
      ];
      function applyVars(bg, text) {
        document.documentElement.style.setProperty("--bg", bg);
        document.documentElement.style.setProperty("--text", `rgb(${text})`);
        document.documentElement.style.setProperty("--text-dim", `rgba(${text}, 0.35)`);
        document.documentElement.style.setProperty("--text-mid", `rgba(${text}, 0.65)`);
      }
      const prevBg = sessionStorage.getItem("prev-bg");
      let currentBg, currentText;
      if (fixedTheme) {
        currentBg = fixedTheme.bg;
        currentText = fixedTheme.text;
      } else {
        const prevIdx = sessionStorage.getItem("theme-idx");
        let idx;
        do { idx = Math.floor(Math.random() * themes.length); }
        while (themes.length > 1 && String(idx) === prevIdx);
        sessionStorage.setItem("theme-idx", String(idx));
        currentBg = themes[idx].bg;
        currentText = themes[idx].text;
      }
      sessionStorage.setItem("prev-bg", currentBg);
      applyVars(currentBg, currentText);
      if (prevBg && prevBg !== currentBg) {
        const overlay = document.createElement("div");
        overlay.style.cssText = "position:fixed;inset:0;z-index:9999;pointer-events:none;background:" + prevBg;
        document.documentElement.appendChild(overlay);
        requestAnimationFrame(() => requestAnimationFrame(() => {
          overlay.style.transition = "opacity 800ms ease";
          overlay.style.opacity = "0";
          setTimeout(() => overlay.remove(), 850);
        }));
      }
    </script>
  </head>
  <body>

    <header id="site-header">
      {back
        ? <a href={backHref} class="back-link">{backLabel}</a>
        : <span class="header-left"><slot name="header-left" /></span>
      }
      <span class="header-right">
        {showClock
          ? <span class="clock-wrap"><span id="clock">--:--</span><span id="date" class="date-dim"></span></span>
          : pageLabel
        }
      </span>
    </header>

    <main class:list={[{ center: centerMain, "full-bleed": fullBleed }]}>
      <slot />
    </main>

    <footer id="site-footer">
      <span class="footer-left"><slot name="footer-left" /></span>
      <span class="footer-right"><slot name="footer-right" /></span>
    </footer>

  </body>
</html>


{showClock && (
  <script>
    function updateClock() {
      const now = new Date();
      const time = now.toLocaleTimeString("en-US", { hour: "2-digit", minute: "2-digit", hour12: false });
      const date = now.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" });
      const c = document.getElementById("clock");
      const d = document.getElementById("date");
      if (c) c.textContent = time;
      if (d) d.textContent = date;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
)}

<style>
  :root {
    --bg: #0c1a12;
    --text: #a8e6be;
    --text-dim: rgba(168, 230, 190, 0.35);
    --text-mid: rgba(168, 230, 190, 0.65);
    --header-h: 60px;
    --footer-h: 50px;
  }


  * { box-sizing: border-box; margin: 0; padding: 0; }

  @keyframes page-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    line-height: 1.75;
    min-height: 100vh;
    animation: page-fade-in 650ms ease both;
  }

  #site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid rgba(226, 230, 232, 0.06);
  }

  .back-link {
    font-size: 100%;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: color 275ms;
  }
  .back-link:hover { color: var(--text); }

  .header-left, .header-right {
    font-size: 100%;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  .clock-wrap {
    display: flex;
    gap: 16px;
    color: var(--text-mid);
    letter-spacing: 0.05em;
  }

  .date-dim { opacity: 0.5; }

  main {
    padding: calc(var(--header-h) + 48px) 24px calc(var(--footer-h) + 48px);
    max-width: 760px;
    margin: 0 auto;
  }

  main.full-bleed {
    padding: var(--header-h) 0 var(--footer-h);
    max-width: none;
  }

  main.center {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    gap: 40px;
  }

  #site-footer {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: var(--footer-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    background: var(--bg);
    border-top: 1px solid rgba(226, 230, 232, 0.06);
  }

  .footer-left, .footer-right {
    font-size: 100%;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    display: flex;
    gap: 24px;
  }

  /* Shared link style for pages to use */
  :global(.dark-link) {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 300ms;
  }
  :global(.dark-link:hover) { color: var(--text); }

  /* Shared section label */
  :global(.section-label) {
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-bottom: 20px;
  }

  /* Shared animated underline link */
  :global(.nav-link) {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 28px;
    text-decoration: none;
    color: var(--text);
    position: relative;
    transition: color 275ms;
  }
  :global(.nav-link .nav-index) {
    font-size: 100%;
    opacity: 0.45;
    transition: opacity 275ms;
    flex-shrink: 0;
    width: 28px;
  }
  :global(.nav-link:hover .nav-index) { opacity: 0.75; }
  :global(.nav-link .nav-label) {
    font-size: 100%;
    font-weight: 300;
    letter-spacing: 0.04em;
  }
  :global(.nav-label .char) {
    color: var(--text-dim);
    transition: color 60ms;
    display: inline;
  }
  :global(.nav-label .char.lit) {
    color: var(--text);
  }
  :global(.nav-label .char.cursor) {
    background: var(--text);
    color: var(--bg);
  }

  /* Header / footer char styles */
  :global(.back-link .char), :global(.header-left .char), :global(.header-right .char),
  :global(.footer-left .char), :global(.footer-right .char) {
    color: var(--text-dim); transition: color 60ms; display: inline;
  }
  :global(.back-link .char.lit), :global(.header-left .char.lit), :global(.header-right .char.lit),
  :global(.footer-left .char.lit), :global(.footer-right .char.lit) { color: var(--text); }
  :global(.back-link .char.cursor), :global(.header-left .char.cursor), :global(.header-right .char.cursor),
  :global(.footer-left .char.cursor), :global(.footer-right .char.cursor) { background: var(--text); color: var(--bg); }

  /* Shared char styles for entry, section, and info sweeps */
  :global(.entry .char), :global(.prose .char), :global(.section > .skills .char),
  :global(.info-title .char), :global(.info-bio .char) {
    color: var(--text-dim); transition: color 60ms; display: inline;
  }
  :global(.entry .char.lit), :global(.prose .char.lit), :global(.section > .skills .char.lit),
  :global(.info-title .char.lit), :global(.info-bio .char.lit) { color: var(--text); }
  :global(.entry .char.cursor), :global(.prose .char.cursor), :global(.section > .skills .char.cursor),
  :global(.info-title .char.cursor), :global(.info-bio .char.cursor) { background: var(--text); color: var(--bg); }

</style>

<script is:inline>
  function splitChars(el) {
    if (el.dataset.split) return;
    el.dataset.split = "1";
    const text = el.textContent ?? "";
    el.innerHTML = [...text]
      .map((ch) => `<span class="char">${ch}</span>`)
      .join("");
  }

  function getVisualLines(chars) {
    const lineMap = new Map();
    chars.forEach(char => {
      const y = Math.round(char.getBoundingClientRect().top / 2) * 2;
      if (!lineMap.has(y)) lineMap.set(y, []);
      lineMap.get(y).push(char);
    });
    return Array.from(lineMap.entries())
      .sort(([a], [b]) => a - b)
      .map(([, line]) => line);
  }

  function sweepRows(target, chars) {
    const timers = target._sweepTimers ?? [];
    timers.forEach(clearTimeout);
    target._sweepTimers = [];
    const rows = getVisualLines(chars);
    const stagger = 80;
    rows.forEach((row, rowIdx) => {
      const rowStart = rowIdx * stagger;
      const msPerChar = Math.min(10, Math.max(2.5, 100 / Math.max(row.length, 1)));
      row.forEach((char, i) => {
        const t = rowStart + i * msPerChar;
        target._sweepTimers.push(setTimeout(() => {
          char.classList.add("cursor");
          char.classList.remove("lit");
        }, t));
        target._sweepTimers.push(setTimeout(() => {
          char.classList.remove("cursor");
          char.classList.add("lit");
        }, t + 60));
      });
    });
  }

  function resetChars(target) {
    (target._sweepTimers ?? []).forEach(clearTimeout);
    target._sweepTimers = [];
    target.querySelectorAll(".char").forEach(c => c.classList.remove("lit", "cursor"));
  }

  function initNavLinks() {
    document.querySelectorAll(".nav-label").forEach(splitChars);
    document.querySelectorAll(".nav-link").forEach((link) => {
      if (link.dataset.cursor) return;
      link.dataset.cursor = "1";
      link.addEventListener("mouseenter", () => {
        sweepRows(link, Array.from(link.querySelectorAll(".char")));
      });
      link.addEventListener("mouseleave", () => resetChars(link));
    });
  }

  function initScrollSweep() {
    // Split chars for all sweepable content
    document.querySelectorAll(".entry").forEach(entry => {
      entry.querySelectorAll(".entry-title, .entry-meta, .entry-date, .entry-body, .skill").forEach(splitChars);
      entry.querySelectorAll(".bullet-list li").forEach(li => {
        if (li.dataset.split) return;
        li.dataset.split = "1";
        li.innerHTML = [...(li.textContent ?? "")].map(ch => `<span class="char">${ch}</span>`).join("");
      });
    });
    document.querySelectorAll(".section").forEach(section => {
      if (!section.querySelector(".prose")) return;
      section.querySelectorAll(".prose p, :scope > .skills .skill").forEach(splitChars);
    });
    document.querySelectorAll(".info-title, .info-bio").forEach(splitChars);

    const rowTimers = new Map();

    function sweepRow(key, chars) {
      (rowTimers.get(key) ?? []).forEach(clearTimeout);
      const timers = [];
      rowTimers.set(key, timers);
      const msPerChar = Math.min(30, Math.max(7.5, 300 / Math.max(chars.length, 1)));
      chars.forEach((char, i) => {
        const t = i * msPerChar;
        timers.push(setTimeout(() => { char.classList.add("cursor"); char.classList.remove("lit"); }, t));
        timers.push(setTimeout(() => { char.classList.remove("cursor"); char.classList.add("lit"); }, t + 60));
      });
    }

    function resetRow(key, chars) {
      (rowTimers.get(key) ?? []).forEach(clearTimeout);
      rowTimers.delete(key);
      chars.forEach(c => c.classList.remove("lit", "cursor"));
    }

    const inViewRows = new Set();
    let rafPending = false;

    function checkRows() {
      const vh = window.innerHeight;
      const allChars = Array.from(document.querySelectorAll(
        ".entry .char, .prose .char, .section > .skills .char, .info-title .char, .info-bio .char"
      ));

      const rowMap = new Map();
      allChars.forEach(char => {
        const rect = char.getBoundingClientRect();
        const docY = Math.round((rect.top + window.scrollY) / 2) * 2;
        if (!rowMap.has(docY)) rowMap.set(docY, []);
        rowMap.get(docY).push(char);
      });

      const style = getComputedStyle(document.documentElement);
      const headerH = parseInt(style.getPropertyValue("--header-h")) || 60;
      const footerH = parseInt(style.getPropertyValue("--footer-h")) || 50;

      const nowInView = new Set();
      rowMap.forEach((chars, docY) => {
        const top = chars[0].getBoundingClientRect().top;
        if (top >= headerH && top < vh - footerH) nowInView.add(docY);
      });

      nowInView.forEach(docY => {
        if (!inViewRows.has(docY)) {
          inViewRows.add(docY);
          const chars = rowMap.get(docY);
          setTimeout(() => sweepRow(docY, chars), 360);
        }
      });

      inViewRows.forEach(docY => {
        if (!nowInView.has(docY)) {
          inViewRows.delete(docY);
          const chars = rowMap.get(docY);
          if (chars) resetRow(docY, chars);
        }
      });
    }

    function onScroll() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => { rafPending = false; checkRows(); });
    }

    checkRows();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
  }

  function initHeaderFooter() {
    const skipIds = new Set(['clock', 'date']);
    const selectors = ['.back-link', '.header-left', '.header-right', '.footer-left', '.footer-right'];
    selectors.forEach(sel => {
      document.querySelectorAll(sel).forEach(container => {
        // Split leaf text elements inside, skipping clock
        const targets = container.children.length
          ? Array.from(container.querySelectorAll('*')).filter(el =>
              !skipIds.has(el.id) && el.children.length === 0 && el.textContent.trim()
            )
          : [container];
        targets.forEach(splitChars);

        container.addEventListener('mouseenter', () =>
          sweepRows(container, Array.from(container.querySelectorAll('.char')))
        );
        container.addEventListener('mouseleave', () => resetChars(container));
      });
    });
  }

  initNavLinks();
  initScrollSweep();
  initHeaderFooter();

</script>
