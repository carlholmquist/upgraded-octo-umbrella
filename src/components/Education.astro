---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{hasEducation && (
  <section>
    <h2 class="text-base font-semibold text-gray-900 mb-3">Education</h2>
    <div class="space-y-6">
      {siteConfig.education.map((edu) => (
        <div>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
            <div>
              <span class="text-sm font-medium text-gray-900">{edu.degree}</span>
              <span class="text-sm text-gray-500 ml-1">— {edu.school}</span>
            </div>
            <span class="text-xs text-gray-400 mt-0.5 sm:mt-0">{edu.dateRange}</span>
          </div>
          {edu.achievements.length > 0 && (
            <ul class="space-y-1 ml-3">
              {edu.achievements.map((achievement) => (
                <li class="text-sm leading-relaxed text-gray-700 flex items-start gap-2">
                  <span class="text-gray-400 mt-1.5 flex-shrink-0">–</span>
                  <span>{achievement}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>
)}
