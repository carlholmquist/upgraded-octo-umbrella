---
import { siteConfig } from "../config";
const aboutParagraphs = siteConfig.aboutMe.split("\n\n").filter(Boolean);
---

<section>
  <h2 class="text-base font-semibold text-gray-900 mb-3">About</h2>
  <div class="space-y-3 text-sm leading-relaxed text-gray-700">
    {aboutParagraphs.map((para) => (
      <p>{para}</p>
    ))}
  </div>
  {siteConfig.skills.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-4">
      {siteConfig.skills.map((skill) => (
        <span class="px-2.5 py-1 bg-gray-100 text-gray-700 text-xs rounded-full">{skill}</span>
      ))}
    </div>
  )}
</section>
