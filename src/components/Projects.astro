---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{hasProjects && (
  <section>
    <h2 class="text-base font-semibold text-gray-900 mb-3">Projects</h2>
    <div class="space-y-6">
      {siteConfig.projects.map((project) => (
        <div>
          {project.link ? (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-gray-900 underline underline-offset-2 hover:text-gray-600 transition-colors"
            >
              {project.name}
            </a>
          ) : (
            <p class="text-sm font-medium text-gray-900">{project.name}</p>
          )}
          <p class="mt-1 text-sm leading-relaxed text-gray-700">{project.description}</p>
          {project.skills && project.skills.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2">
              {project.skills.map((skill) => (
                <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded">{skill}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
)}
