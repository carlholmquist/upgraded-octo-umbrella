---
import { siteConfig } from "../config";
---

<header>
  <p class="text-xs text-gray-400 uppercase tracking-widest mb-3">About</p>
  <h1 class="text-4xl font-bold text-gray-900 mb-2">{siteConfig.name}</h1>
  <p class="text-lg text-gray-500 mb-6">{siteConfig.title}</p>
  <div class="flex flex-wrap gap-x-5 gap-y-2 text-gray-500">
    {siteConfig.social?.email && (
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="text-sm underline underline-offset-2 hover:text-gray-900 transition-colors"
      >
        Email
      </a>
    )}
    {siteConfig.social?.linkedin && (
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm underline underline-offset-2 hover:text-gray-900 transition-colors"
      >
        LinkedIn
      </a>
    )}
    {siteConfig.social?.github && (
      <a
        href={siteConfig.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm underline underline-offset-2 hover:text-gray-900 transition-colors"
      >
        GitHub
      </a>
    )}
    {siteConfig.social?.twitter && (
      <a
        href={siteConfig.social.twitter}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm underline underline-offset-2 hover:text-gray-900 transition-colors"
      >
        Twitter
      </a>
    )}
  </div>
</header>
