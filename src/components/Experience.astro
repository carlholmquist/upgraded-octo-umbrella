---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{hasExperience && (
  <section>
    <h2 class="text-base font-semibold text-gray-900 mb-3">Experience</h2>
    <div class="space-y-6">
      {siteConfig.experience.map((exp) => (
        <div>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
            <div>
              <span class="text-sm font-medium text-gray-900">{exp.title}</span>
              <span class="text-sm text-gray-500 ml-1">— {exp.company}</span>
            </div>
            <span class="text-xs text-gray-400 mt-0.5 sm:mt-0">{exp.dateRange}</span>
          </div>
          <ul class="space-y-1 ml-3">
            {exp.bullets.map((bullet) => (
              <li class="text-sm leading-relaxed text-gray-700 flex items-start gap-2">
                <span class="text-gray-400 mt-1.5 flex-shrink-0">–</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}
