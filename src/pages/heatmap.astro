---
import DarkLayout from "../layouts/DarkLayout.astro";
---

<DarkLayout title="Heatmap — Carl Holmquist" back pageLabel="Heatmap" fullBleed>
  <link slot="head" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <span slot="footer-left">holmquist.studio</span>

  <div id="map-loader"><span id="loader-text">loading</span></div>
  <div id="map"></div>
  <button id="map-toggle" aria-label="Toggle satellite view">satellite</button>
</DarkLayout>

<style>
  #map-loader {
    position: absolute;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: opacity 400ms ease 300ms;
  }

  #map-loader.done {
    opacity: 0;
  }

  #loader-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  :global(#loader-text .char) {
    color: var(--text-dim);
    transition: color 60ms;
    display: inline;
  }

  :global(#loader-text .char.lit) { color: var(--text); }

  :global(#loader-text .char.cursor) {
    background: var(--text);
    color: var(--bg);
  }

  #map {
    width: 100%;
    height: calc(100vh - var(--header-h) - var(--footer-h));
  }

  /* Hide Leaflet's default attribution box styling conflict */
  :global(.leaflet-container) {
    background: var(--bg) !important;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
  }


  :global(.leaflet-map-color-overlay) {
    position: absolute;
    inset: 0;
    background: var(--text);
    mix-blend-mode: color;
    opacity: 0.7;
    pointer-events: none;
    z-index: 350;
  }

  :global(.leaflet-control-attribution) {
    display: none;
  }

  :global(.leaflet-control-zoom a) {
    background: var(--bg) !important;
    color: var(--text-mid) !important;
    border-color: var(--text-dim) !important;
    font-family: 'IBM Plex Mono', monospace !important;
  }

  :global(.leaflet-control-zoom a:hover) {
    color: var(--text) !important;
  }

  #map-toggle {
    position: absolute;
    bottom: calc(var(--footer-h) + 16px);
    right: 16px;
    z-index: 1000;
    background: var(--bg);
    color: var(--text-dim);
    border: 1px solid var(--text-dim);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 6px 12px;
    cursor: pointer;
    transition: color 275ms, border-color 275ms;
  }

  #map-toggle:hover {
    color: var(--text);
    border-color: var(--text);
  }
</style>

<script is:inline>
  (function () {
    const leafletScript = document.createElement("script");
    leafletScript.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
    leafletScript.onload = initMap;
    document.head.appendChild(leafletScript);
  })();

  async function initMap() {
    const loader = document.getElementById("map-loader");
    const loaderText = document.getElementById("loader-text");
    loaderText.innerHTML = [...loaderText.textContent].map(ch => `<span class="char">${ch}</span>`).join("");
    const chars = Array.from(loaderText.querySelectorAll(".char"));
    let loaderTimers = [];
    let looping = true;

    function runLoaderSweep() {
      if (!looping) return;
      loaderTimers.forEach(clearTimeout);
      loaderTimers = [];
      chars.forEach(c => c.classList.remove("lit", "cursor"));
      const msPerChar = 80;
      chars.forEach((char, i) => {
        loaderTimers.push(setTimeout(() => { char.classList.add("cursor"); char.classList.remove("lit"); }, i * msPerChar));
        loaderTimers.push(setTimeout(() => { char.classList.remove("cursor"); char.classList.add("lit"); }, i * msPerChar + 60));
      });
      loaderTimers.push(setTimeout(() => {
        chars.forEach(c => c.classList.remove("lit", "cursor"));
        loaderTimers.push(setTimeout(runLoaderSweep, 200));
      }, chars.length * msPerChar + 200));
    }
    runLoaderSweep();

    const res = await fetch("https://studiobackend.onrender.com/geojson");
    const geojson = await res.json();

    const map = L.map("map", {
      zoomControl: true,
      attributionControl: true,
    });

    const darkTiles = L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", {
      attribution: "© OpenStreetMap © CartoDB",
      subdomains: "abcd",
      maxZoom: 19,
    });

    const satTiles = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", {
      attribution: "© Esri",
      maxZoom: 19,
    });

    const satLabels = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}", {
      maxZoom: 19,
    });

    darkTiles.addTo(map);

    // Color overlay — tints grayscale tiles to theme color
    const container = map.getContainer();
    container.style.isolation = "isolate";
    const colorOverlay = document.createElement("div");
    colorOverlay.className = "leaflet-map-color-overlay";
    container.appendChild(colorOverlay);

    const tilePane = map.getPane("tilePane");
    tilePane.style.filter = "grayscale(1) brightness(0.6)";
    let isSatellite = false;

    document.getElementById("map-toggle").addEventListener("click", () => {
      isSatellite = !isSatellite;
      if (isSatellite) {
        map.removeLayer(darkTiles);
        satTiles.addTo(map);
        satLabels.addTo(map);
        tilePane.style.filter = "none";
        colorOverlay.style.display = "none";
        document.getElementById("map-toggle").textContent = "styled";
      } else {
        map.removeLayer(satTiles);
        map.removeLayer(satLabels);
        darkTiles.addTo(map);
        tilePane.style.filter = "grayscale(1) brightness(0.6)";
        colorOverlay.style.display = "";
        document.getElementById("map-toggle").textContent = "satellite";
      }
    });

    // Read theme color from CSS vars
    const style = getComputedStyle(document.documentElement);
    const themeText = style.getPropertyValue("--text").trim();

    // Blurred glow pane
    map.createPane("glowPane");
    map.getPane("glowPane").style.filter = "blur(8px)";
    map.createPane("corePane");

    const glowRenderer = L.canvas({ pane: "glowPane" });
    const coreRenderer = L.canvas({ pane: "corePane" });

    const allLatLngs = [];

    geojson.features.forEach((f) => {
      if (f.geometry.type !== "LineString") return;
      const latlngs = f.geometry.coordinates.map(([lng, lat]) => {
        allLatLngs.push([lat, lng]);
        return [lat, lng];
      });

      // Blurred glow in theme color
      L.polyline(latlngs, { renderer: glowRenderer, color: themeText, weight: 16, opacity: 0.06, smoothFactor: 1 }).addTo(map);
      L.polyline(latlngs, { renderer: glowRenderer, color: themeText, weight:  8, opacity: 0.12, smoothFactor: 1 }).addTo(map);

      // Sharp core
      L.polyline(latlngs, { renderer: coreRenderer, color: themeText, weight: 1.5, opacity: 0.35, smoothFactor: 1 }).addTo(map);
    });

    // Center on the last route's midpoint
    const lastFeature = [...geojson.features].reverse().find((f) => f.geometry.type === "LineString");
    if (lastFeature) {
      const coords = lastFeature.geometry.coordinates;
      const mid = coords[Math.floor(coords.length / 2)];
      map.setView([mid[1], mid[0]], 13);
    } else if (allLatLngs.length > 0) {
      map.fitBounds(L.latLngBounds(allLatLngs), { padding: [40, 40] });
    }

    looping = false;
    loaderTimers.forEach(clearTimeout);
    loader.classList.add("done");
  }
</script>
