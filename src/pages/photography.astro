---
import DarkLayout from "../layouts/DarkLayout.astro";

const cloudName = "drey6ump8";

const photos: { path: string; caption?: string }[] = [
  { path: "v1776373536/DSCF0284_c5tskx.jpg" },
  { path: "v1776383577/DSCF2804_ql8ugy.jpg" },
  { path: "v1776383577/DSCF2495_hng6mm.jpg" },
  { path: "v1776383577/DSCF7366_mfwka5.jpg" },
  { path: "v1776396125/DSCF2364_cn1x1l.jpg" },
  { path: "v1776396125/cpm35_2026-01-14_162619.161_r4usda.jpg" },
  { path: "v1776396124/DSCF2432_ufdj2b.jpg" },
  { path: "v1776396125/DSCF2503_pyo9at.jpg" },
  { path: "v1776396124/DSCF2283_oxboob.jpg" },
  { path: "v1776396124/DSCF2486_f0xd32.jpg" },
  { path: "v1776396124/DSCF2963_oqf9do.jpg" },
  { path: "v1776396124/DSCF2582_u1fz7b.jpg" },
  { path: "v1776396124/DSCF2627_nys8gk.jpg" },
  { path: "v1776396124/DSCF2513_rb7ytv.jpg" },
  { path: "v1776396124/DSCF2775_nzptbj.jpg" },
  { path: "v1776396124/DSCF2831_rmajov.jpg" },
  { path: "v1776396123/DSCF3048_ck3cod.jpg" },
];

function thumb(path: string) {
  return `https://res.cloudinary.com/${cloudName}/image/upload/q_auto,f_auto,w_800/${path}`;
}

function full(path: string) {
  return `https://res.cloudinary.com/${cloudName}/image/upload/q_auto,f_auto,w_1800/${path}`;
}
---

<DarkLayout title="Photography — Carl Holmquist" back pageLabel="Photographs" fullBleed>
  <span slot="footer-left">holmquist.studio</span>

  <div class="photo-list">
    {photos.map((photo, i) => (
      <button
        class="photo-btn"
        data-full={full(photo.path)}
        data-index={i}
        aria-label={photo.caption ?? `Photo ${i + 1}`}
      >
        <img
          src={thumb(photo.path)}
          alt={photo.caption ?? ""}
          loading="lazy"
          class="photo-img"
        />
        {photo.caption && <p class="photo-caption">{photo.caption}</p>}
      </button>
    ))}
  </div>

  <!-- Lightbox -->
  <div
    id="lightbox"
    role="dialog"
    aria-modal="true"
  >
    <button id="lightbox-close" class="lightbox-close" aria-label="Close">×</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
  </div>

  <script>
    const lightbox = document.getElementById("lightbox")!;
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const closeBtn = document.getElementById("lightbox-close")!;

    document.querySelectorAll<HTMLButtonElement>("[data-full]").forEach((btn) => {
      btn.addEventListener("click", () => {
        lightboxImg.src = btn.dataset.full!;
        lightbox.classList.add("open");
        document.body.style.overflow = "hidden";
      });
    });

    function closeLightbox() {
      lightbox.classList.remove("open");
      lightboxImg.src = "";
      document.body.style.overflow = "";
    }

    closeBtn.addEventListener("click", closeLightbox);
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLightbox(); });
  </script>
</DarkLayout>

<style>
  .photo-list {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    width: 100%;
  }

  .photo-btn {
    display: block;
    background: none;
    border: none;
    padding: 0;
    cursor: zoom-in;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    filter: brightness(0.88);
    transition: filter 300ms;
  }

  .photo-btn:hover .photo-img {
    filter: brightness(1);
  }

  .photo-caption { display: none; }

  @media (max-width: 520px) {
    .photo-list { grid-template-columns: repeat(2, 1fr); }
  }

  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  #lightbox.open { display: flex; }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: rgba(226, 230, 232, 0.5);
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    transition: color 275ms;
  }
  .lightbox-close:hover { color: #e2e6e8; }

  .lightbox-img {
    max-height: 90vh;
    max-width: 100%;
    object-fit: contain;
  }
</style>
