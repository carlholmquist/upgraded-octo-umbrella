---
import DarkLayout from "../layouts/DarkLayout.astro";
import { siteConfig } from "../config";

const aboutParagraphs = siteConfig.aboutMe.split("\n\n").filter(Boolean);
---

<DarkLayout title={siteConfig.name} back pageLabel={siteConfig.name}>
  <a slot="footer-left" href={`mailto:${siteConfig.social.email}`} class="dark-link">{siteConfig.social.email}</a>
  <span slot="footer-right">
    {siteConfig.social.linkedin && <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="dark-link">LinkedIn</a>}
    {siteConfig.social.github && <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="dark-link">GitHub</a>}
  </span>

  <section class="section">
    <h2 class="section-label">About</h2>
    <div class="prose">
      {aboutParagraphs.map((p) => <p>{p}</p>)}
    </div>
    <div class="skills">
      {siteConfig.skills.map((s) => <span class="skill">{s}</span>)}
    </div>
  </section>

  {siteConfig.projects.length > 0 && (
    <section class="section">
      <h2 class="section-label">Projects</h2>
      <div class="entries">
        {siteConfig.projects.map((project, i) => (
          <div class="entry">
            <div class="entry-head">
              <span class="entry-index">{String(i + 1).padStart(3, '0')}</span>
              {project.link
                ? <a href={project.link} target="_blank" rel="noopener noreferrer" class="entry-title link">{project.name}</a>
                : <span class="entry-title">{project.name}</span>
              }
            </div>
            <p class="entry-body">{project.description}</p>
            {project.skills.length > 0 && (
              <div class="skills" style="margin-top:10px">
                {project.skills.map((s) => <span class="skill">{s}</span>)}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  {siteConfig.experience.length > 0 && (
    <section class="section">
      <h2 class="section-label">Experience</h2>
      <div class="entries">
        {siteConfig.experience.map((exp, i) => (
          <div class="entry">
            <div class="entry-head">
              <span class="entry-index">{String(i + 1).padStart(3, '0')}</span>
              <span class="entry-title">{exp.title}</span>
              <span class="entry-meta">— {exp.company}</span>
              <span class="entry-date">{exp.dateRange}</span>
            </div>
            <ul class="bullet-list">
              {exp.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  {siteConfig.education.length > 0 && (
    <section class="section">
      <h2 class="section-label">Education</h2>
      <div class="entries">
        {siteConfig.education.map((edu, i) => (
          <div class="entry">
            <div class="entry-head">
              <span class="entry-index">{String(i + 1).padStart(3, '0')}</span>
              <span class="entry-title">{edu.degree}</span>
              <span class="entry-meta">— {edu.school}</span>
              <span class="entry-date">{edu.dateRange}</span>
            </div>
            <ul class="bullet-list">
              {edu.achievements.map((a) => <li>{a}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}
</DarkLayout>

<style>
  .section { margin-bottom: 56px; }

  .prose {
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 20px;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    border: 1px solid rgba(226, 230, 232, 0.12);
    padding: 3px 10px;
    border-radius: 2px;
  }

  .entries { display: flex; flex-direction: column; gap: 36px; }

  .entry .entry-index {
    opacity: 0.25;
    transition: opacity 300ms;
  }
  .entry:hover .entry-index { opacity: 0.85; }

  @media (hover: none) {
    .entry.in-view .entry-index { opacity: 0.85; }
  }

  .entry-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 10px;
    position: relative;
    padding-bottom: 4px;
    cursor: default;
  }

  .entry-head::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--text);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 275ms cubic-bezier(0.86, 0, 0.07, 1);
  }

  .entry:hover .entry-head::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (hover: none) {
    .entry.in-view .entry-head::after {
      transform: scaleX(1);
      transform-origin: left;
    }
  }

  .entry-index {
    font-size: 100%;
    color: var(--text-dim);
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 275ms;
  }

  .entry-title { font-size: 100%; font-weight: 400; color: var(--text); }

  .entry-title.link {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(226, 230, 232, 0.25);
    transition: text-decoration-color 275ms;
  }
  .entry-title.link:hover { text-decoration-color: var(--text); }

  .entry-meta { font-size: 100%; color: var(--text); }

  .entry-date { font-size: 11px; color: var(--text-dim); margin-left: auto; }

  .entry-body { color: var(--text); }

  .bullet-list { list-style: none; display: flex; flex-direction: column; gap: 6px; padding: 0; margin: 0; }

  .bullet-list li {
    color: var(--text);
    padding-left: 33px;
    position: relative;
  }

  .bullet-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--text-dim);
  }
</style>

