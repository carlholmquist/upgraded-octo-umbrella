// ---------- open entry ----------

function openName(name, skipEcho) {
  name = name.replace(/\/$/, '');
  const e = findEntry(cwd, name);
  if (!e) {
    if (!skipEcho) appendPromptEcho(cwd, 'open ' + name);
    appendLine('dim', 'no such file or directory: ' + name);
    appendSpacer();
    scrollBottom();
    return;
  }
  if (e.type === 'photo') {
    if (!skipEcho) appendPromptEcho(cwd, 'open ' + name);
    appendInlinePhoto(e);
    appendSpacer();
    scrollBottom();
    return;
  }
  if (e.type === 'bookmark') {
    if (!skipEcho) appendPromptEcho(cwd, 'open ' + name);
    appendLine('mid', '→ ' + e.url);
    appendSpacer();
    scrollBottom();
    window.open(e.url, '_blank', 'noopener');
    return;
  }
  if (e.type === 'file') {
    const echoEl = skipEcho ? null : appendPromptEcho(cwd, 'cat ' + name);
    if (e.blocks) appendBlocks(e.blocks);
    else if (e.cat) appendCat('mid', e.cat);
    if (e.links?.length) appendLinks(e.links);
    if (!e.blocks && !e.cat && !e.links?.length) appendLine('dim', '(empty)');
    appendSpacer();
    if (echoEl) smartScroll(echoEl); else scrollBottom();
    return;
  }
  if (e.type === 'link') {
    if (!skipEcho) appendPromptEcho(cwd, 'open ' + name);
    appendLine('mid', '→ ' + e.href);
    appendSpacer();
    scrollBottom();
    setTimeout(() => { window.location.href = e.href; }, 300);
    return;
  }
  if (e.type === 'dir' && e.ascii) {
    if (!skipEcho) appendPromptEcho(cwd, 'open ' + name);
    appendAsciiHeatmap(e.ascii);
    return;
  }
  if (e.type === 'dir') {
    if (!skipEcho) appendPromptEcho(cwd, 'cd ' + name);
    cwd = cwd === '~' ? '~/' + name : cwd + '/' + name;
    updateFooter();
    appendSpacer();
    const lsEcho = appendPromptEcho(cwd, 'ls');
    if (cwd === '~/photography') appendPhotoGallery(visible(listAt(cwd), false));
    else if (cwd === '~/bookmarks') appendBookmarkList(visible(listAt(cwd), false));
    else appendLsLong(visible(listAt(cwd), false));
    appendSpacer();
    if (cwd === '~/photography' || cwd === '~/bookmarks') scrollToEl(lsEcho);
    else scrollBottom();
    return;
  }
  if (!skipEcho) appendPromptEcho(cwd, 'open ' + name);
  appendLine('dim', 'not sure how to open: ' + name);
  appendSpacer();
  scrollBottom();
}

function goUp(skipEcho) {
  if (cwd === '~') return;
  const parent = cwd.split('/').slice(0, -1).join('/') || '~';
  if (!skipEcho) appendPromptEcho(cwd, 'cd ..');
  cwd = parent;
  updateFooter();
  appendSpacer();
  appendPromptEcho(cwd, 'ls');
  appendLsLong(visible(listAt(cwd), false));
  appendSpacer();
  scrollBottom();
}

// ---------- command parser ----------
function run(raw) {
  const cmd = raw.trim();
  if (!cmd) { appendPromptEcho(cwd, raw); scrollBottom(); return; }

  const parts = cmd.split(/\s+/);
  const head = parts[0];
  const rest = parts.slice(1);

  const cmdEcho = appendPromptEcho(cwd, raw);

  if (head === 'ls') {
    const showHidden = rest.some(a => /^-[la]*a/.test(a) || a === '--all');
    const rows = visible(listAt(cwd), showHidden);
    if (cwd === '~/photography') appendPhotoGallery(rows);
    else if (cwd === '~/bookmarks') appendBookmarkList(rows);
    else appendLsLong(rows);
    appendSpacer();
    if (cwd === '~/photography' || cwd === '~/bookmarks') scrollToEl(cmdEcho);
    else scrollBottom();
    return;
  }

  if (head === 'cat') {
    const tgt = rest[0];
    const e = tgt ? findEntry(cwd, tgt) : null;
    if (!e) {
      appendLine('dim', 'cat: ' + (tgt || '(missing operand)') + ': no such file');
    } else if (e.blocks || e.cat || e.links?.length) {
      if (e.blocks) appendBlocks(e.blocks);
      else if (e.cat) appendCat('mid', e.cat);
      if (e.links?.length) appendLinks(e.links);
    } else {
      appendLine('dim', e.name + ': is a directory. try `cd ' + e.name + '`.');
    }
    appendSpacer();
    scrollBottom();
    return;
  }

  if (head === 'cd') {
    const tgt = rest[0];
    if (!tgt || tgt === '~' || tgt === '/') {
      if (cwd !== '~') {
        cwd = '~'; updateFooter(); appendSpacer();
        appendPromptEcho('~', 'ls');
        appendLsLong(visible(HOME, false));
      } else {
        appendLine('dim', 'already home.');
      }
      appendSpacer(); scrollBottom(); return;
    }
    const resolved = resolvePath(cwd, tgt);
    if (resolved === '~') {
      cwd = '~'; updateFooter(); appendSpacer();
      appendPromptEcho('~', 'ls');
      appendLsLong(visible(HOME, false));
      appendSpacer(); scrollBottom(); return;
    }
    const parentPath = resolved.split('/').slice(0, -1).join('/') || '~';
    const entryName = resolved.split('/').pop();
    const entry = listAt(parentPath).find(e => e.name === entryName);
    const dirEntries = listAt(resolved);
    if (entry?.ascii) { appendAsciiHeatmap(entry.ascii); return; }
    if (dirEntries.length || entry?.type === 'dir') {
      cwd = resolved; updateFooter(); appendSpacer();
      const lsEcho = appendPromptEcho(cwd, 'ls');
      if (cwd === '~/photography') appendPhotoGallery(visible(listAt(cwd), false));
      else if (cwd === '~/bookmarks') appendBookmarkList(visible(listAt(cwd), false));
      else appendLsLong(visible(listAt(cwd), false));
      appendSpacer();
      if (cwd === '~/photography' || cwd === '~/bookmarks') scrollToEl(lsEcho);
      else scrollBottom();
      return;
    }
    if (entry) { cwd = parentPath; updateFooter(); openName(entryName, true); return; }
    appendLine('dim', 'no such file or directory: ' + tgt);
    appendSpacer(); scrollBottom(); return;
  }

  if (head === 'open') {
    const tgt = rest[0];
    if (!tgt) { appendLine('dim', 'open: missing operand'); appendSpacer(); scrollBottom(); return; }
    openName(tgt.replace(/\/$/, ''), true);
    return;
  }

  if (head === 'tree') {
    appendLine('mid', asciiTree(cwd));
    appendSpacer();
    scrollBottom();
    return;
  }

  if (head === 'help' || head === '?') {
    appendLine('mid', [
      '  ls [-a] [-l]    list',
      '  cat <name>      print a file',
      '  cd  <name>      enter a directory',
      '  cd  ..          go up',
      '  tree            show all',
      '  search <query>  brave search',
      '  whoami · pwd · clear',
      "  exit            (please don't)",
      '',
      '  or just click any name.',
    ].join('\n'));
    appendSpacer();
    scrollBottom();
    return;
  }

  if (head === 'search' || head === 's') {
    const query = rest.join(' ').trim();
    if (!query) {
      appendLine('dim', 'usage: search <query>');
      appendSpacer(); scrollBottom(); return;
    }
    const container = document.createElement('div');
    const status = document.createElement('div');
    status.className = 'term-line dim';
    status.textContent = 'searching_';
    container.appendChild(status);
    scrollEl.appendChild(container);
    appendSpacer();
    scrollBottom();
    fetch('https://winter-dream-e43b.holmquist-carl.workers.dev/?q=' + encodeURIComponent(query), {
      headers: { Accept: 'application/json' },
    })
      .then(r => r.json())
      .then(data => {
        container.innerHTML = '';
        const items = data?.web?.results ?? [];
        if (!items.length) {
          const msg = document.createElement('div');
          msg.className = 'term-line dim';
          msg.textContent = 'no results for "' + query + '"';
          container.appendChild(msg);
        } else {
            const block = document.createElement('div');
          block.className = 'ls-block';
          const total = document.createElement('div');
          total.className = 'term-line dim';
          total.textContent = 'total ' + items.length;
          block.appendChild(total);
          items.forEach(item => {
            let domain = '—';
            try { domain = new URL(item.url).hostname.replace(/^www\./, ''); } catch {}

            const row = document.createElement('a');
            row.href = item.url;
            row.target = '_blank';
            row.rel = 'noopener noreferrer';
            row.className = 'ls-row type-link';
            row.style.gridTemplateColumns = '100px 160px 1fr';
            row.innerHTML =
              `<span>lrwxr-xr-x</span>` +
              `<span style="color:var(--text-mid);overflow:hidden;text-overflow:ellipsis">${esc(domain)}</span>` +
              `<span class="name" style="overflow:hidden;text-overflow:ellipsis">${esc(item.title)} →</span>`;
            block.appendChild(row);
          });
          const googleRow = document.createElement('a');
          googleRow.href = 'https://www.google.com/search?q=' + encodeURIComponent(query);
          googleRow.target = '_blank';
          googleRow.rel = 'noopener noreferrer';
          googleRow.className = 'ls-row type-link';
          googleRow.style.gridTemplateColumns = '100px 160px 1fr';
          googleRow.innerHTML =
            `<span>lrwxr-xr-x</span>` +
            `<span style="color:var(--text-mid)">google.com</span>` +
            `<span class="name">search google for "${esc(query)}" →</span>`;
          block.appendChild(googleRow);
          container.appendChild(block);
        }
        scrollBottom();
      })
      .catch(() => {
        container.innerHTML = '';
        const msg = document.createElement('div');
        msg.className = 'term-line dim';
        msg.textContent = 'error fetching results';
        container.appendChild(msg);
        scrollBottom();
      });
    return;
  }

  if (head === 'whoami') {
    appendLine('mid', 'carl holmquist. a stranger, otherwise.');
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'pwd') {
    appendLine('mid', cwd.replace('~', '/home/carl'));
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'clear') {
    scrollEl.innerHTML = '';
    scrollBottom(); return;
  }
  if (head === 'exit' || head === 'logout') {
    appendLine('dim', "you can't leave. you can only minimise the tab.");
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'sudo') {
    appendLine('dim', 'nice try.');
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'rm') {
    appendLine('dim', "i'd rather you didn't.");
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'echo') {
    appendLine('mid', rest.join(' '));
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'date') {
    appendLine('mid', new Date().toString());
    appendSpacer(); scrollBottom(); return;
  }
  if (head === 'hej' || head === 'hi' || head === 'hello') {
    appendLine('mid', 'hej. ' + (Math.random() < 0.5 ? '☕' : ''));
    appendSpacer(); scrollBottom(); return;
  }

  appendLine('dim', 'command not found: ' + head + '. try `help`.');
  appendSpacer();
  scrollBottom();
}

// ---------- input ----------
inputEl.addEventListener('input', () => {
  ghostEl.textContent = inputEl.value;
});

function hideHint() {
  const hint = document.getElementById('hint-enter');
  if (hint) hint.style.display = 'none';
}

inputEl.addEventListener('keydown', e => {
  // If pre-fill is active and user types a printable character, clear it so they start fresh
  if (prefillActive && e.key.length === 1 && !e.ctrlKey && !e.metaKey && e.key !== 'Enter') {
    prefillActive = false;
    inputEl.value = '';
    ghostEl.textContent = '';
  }
  if (e.key !== 'Tab') hideHint();
  if (e.key === 'Enter') {
    e.preventDefault();
    const v = inputEl.value;
    inputEl.value = '';
    ghostEl.textContent = '';
    if (v.trim()) history.push(v);
    histIdx = -1;
    const wasFirst = firstCommand;
    firstCommand = false;
    prefillActive = false;
    run(v);
    if (wasFirst) {
      appendSpacer();
      appendPromptEcho('~', 'ls');
      appendLsLong(visible(HOME, false));
      appendSpacer();
      scrollBottom();
    }
    return;
  }
  if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (!history.length) return;
    const next = histIdx === -1 ? history.length - 1 : Math.max(0, histIdx - 1);
    histIdx = next;
    inputEl.value = history[next];
    ghostEl.textContent = history[next];
    return;
  }
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (histIdx === -1) return;
    const next = histIdx + 1;
    if (next >= history.length) {
      histIdx = -1;
      inputEl.value = '';
      ghostEl.textContent = '';
    } else {
      histIdx = next;
      inputEl.value = history[next];
      ghostEl.textContent = history[next];
    }
    return;
  }
  if (e.key === 'Tab') {
    e.preventDefault();
    const parts = inputEl.value.split(/\s+/);
    const last = parts[parts.length - 1] || '';
    if (!last) return;
    const matches = listAt(cwd).filter(f => f.name.startsWith(last));
    if (matches.length === 1) {
      parts[parts.length - 1] = matches[0].name + (matches[0].type === 'dir' ? '/' : '');
      inputEl.value = parts.join(' ');
      ghostEl.textContent = inputEl.value;
    } else if (matches.length > 1) {
      appendPromptEcho(cwd, inputEl.value + '<TAB>');
      appendLine('dim', matches.map(m => m.name).join('   '));
      appendSpacer();
      scrollBottom();
    }
    return;
  }
  if ((e.ctrlKey || e.metaKey) && e.key === 'l') {
    e.preventDefault();
    scrollEl.innerHTML = '';
    return;
  }
});


document.addEventListener('click', e => {
  if (e.target.closest('a, button, input, textarea')) return;
  const isTouchDevice = window.matchMedia('(hover: none) and (pointer: coarse)').matches;
  if (isTouchDevice && !e.target.closest('#prompt-live')) return;
  inputEl.focus({ preventScroll: true });
});

if (helpBtn) {
  helpBtn.addEventListener('click', () => {
    run('help');
    inputEl.focus({ preventScroll: true });
  });
}

if (promptHomeEl) {
  promptHomeEl.addEventListener('click', e => {
    e.stopPropagation();
    if (cwd === '~') return;
    appendPromptEcho(cwd, 'cd ~');
    cwd = '~';
    updateFooter();
    appendSpacer();
    appendPromptEcho('~', 'ls');
    appendLsLong(visible(HOME, false));
    appendSpacer();
    scrollBottom();
    inputEl.focus({ preventScroll: true });
  });
}

// ---------- mobile keyboard ----------
if (window.visualViewport) {
  window.visualViewport.addEventListener('resize', () => {
    if (document.activeElement !== inputEl) return;
    requestAnimationFrame(() => {
      const promptEl = document.getElementById('prompt-live');
      if (!promptEl) return;
      const vv = window.visualViewport;
      const rect = promptEl.getBoundingClientRect();
      const visibleBottom = vv.offsetTop + vv.height;
      if (rect.bottom > visibleBottom - 8) {
        window.scrollBy({ top: rect.bottom - visibleBottom + 8, behavior: 'instant' });
      }
    });
  });
}

// ---------- boot ----------
function boot() {
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) +
    ', ' + now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false }) + '.';
  (TERMINAL.loginLines ?? []).forEach(line =>
    appendLine('dim', line.replace('{date}', dateStr))
  );
  appendSpacer();
  updateFooter();
  const bootPath = new URLSearchParams(window.location.search).get('boot');
  if (bootPath && listAt('~/' + bootPath).length) {
    appendPromptEcho('~', 'cd ' + bootPath);
    cwd = '~/' + bootPath;
    updateFooter();
    appendSpacer();
    const entries = visible(listAt(cwd), false);
    const firstEcho = appendPromptEcho(cwd, 'cat ' + (entries.find(e => e.type === 'file')?.name ?? ''));
    entries.filter(e => e.type === 'file').forEach((e, i) => {
      if (i > 0) appendPromptEcho(cwd, 'cat ' + e.name);
      if (e.blocks) appendBlocks(e.blocks);
      else if (e.cat) appendCat('mid', e.cat);
      if (e.links?.length) appendLinks(e.links);
      appendSpacer();
    });
    history.scrollRestoration = 'manual';
    requestAnimationFrame(() => requestAnimationFrame(() => window.scrollTo({ top: 0 })));
  } else {
    inputEl.value = 'cat .intro';
    ghostEl.textContent = 'cat .intro';
  }

  const isTouchDevice = window.matchMedia('(hover: none) and (pointer: coarse)').matches;
  if (!isTouchDevice) inputEl.focus({ preventScroll: true });
}

boot();

})();
</script>
