// ---------- ascii heatmap ----------
async function appendAsciiHeatmap(url) {
  const statusEl = document.createElement('div');
  statusEl.className = 'term-line dim';
  statusEl.textContent = 'fetching routes_';
  scrollEl.appendChild(statusEl);
  scrollBottom();

  try {
    const res = await fetch(url);
    const geojson = await res.json();

    const lines = [];
    geojson.features.forEach(f => {
      if (f.geometry.type === 'LineString') lines.push(f.geometry.coordinates);
    });
    if (!lines.length) { statusEl.textContent = 'no route data'; return; }

    // Fit viewport to last 10 routes' extent
    const lastLine = lines[lines.length - 1];
    const lastPt = lastLine[lastLine.length - 1];
    const recentLines = lines.slice(-10);

    let rMinLat = Infinity, rMaxLat = -Infinity, rMinLng = Infinity, rMaxLng = -Infinity;
    recentLines.forEach(coords => coords.forEach(([lng, lat]) => {
      if (lat < rMinLat) rMinLat = lat; if (lat > rMaxLat) rMaxLat = lat;
      if (lng < rMinLng) rMinLng = lng; if (lng > rMaxLng) rMaxLng = lng;
    }));

    const cLat = (rMinLat + rMaxLat) / 2;
    const cLng = (rMinLng + rMaxLng) / 2;

    // Add 30% padding, enforce a minimum viewport so very short routes don't over-zoom
    const MIN_HALF_LAT = 0.008;
    const padLat = Math.max((rMaxLat - rMinLat) * 0.65, MIN_HALF_LAT);
    const padLng = Math.max((rMaxLng - rMinLng) * 0.65, MIN_HALF_LAT / Math.cos(cLat * Math.PI / 180));

    const minLat = cLat - padLat, maxLat = cLat + padLat;
    const minLng = cLng - padLng, maxLng = cLng + padLng;
    const dLat = maxLat - minLat, dLng = maxLng - minLng;

    // Grid sized so chars fill a square: ROWS = COLS * charWidth/charHeight
    const COLS = 74;
    const ROWS = Math.round(COLS * (8 / 22)); // ~27 — square visual

    const grid = Array.from({length: ROWS}, () => new Uint8Array(COLS));

    function project([lng, lat]) {
      const c = Math.round((lng - minLng) / dLng * (COLS - 1));
      const r = Math.round((maxLat - lat) / dLat * (ROWS - 1));
      return [Math.max(0, Math.min(COLS-1, c)), Math.max(0, Math.min(ROWS-1, r))];
    }

    function bresenham(x0, y0, x1, y1) {
      const dx = Math.abs(x1-x0), dy = Math.abs(y1-y0);
      const sx = x0<x1?1:-1, sy = y0<y1?1:-1;
      let err = dx-dy;
      for (let i=0; i<2000; i++) {
        if (grid[y0][x0] < 255) grid[y0][x0]++;
        if (x0===x1 && y0===y1) break;
        const e2 = 2*err;
        if (e2>-dy) { err-=dy; x0+=sx; }
        if (e2<dx)  { err+=dx; y0+=sy; }
      }
    }

    lines.forEach(coords => {
      for (let i=0; i<coords.length-1; i++) {
        const [c0,r0] = project(coords[i]);
        const [c1,r1] = project(coords[i+1]);
        bresenham(c0, r0, c1, r1);
      }
    });

    let maxCount = 0;
    grid.forEach(row => row.forEach(v => { if (v > maxCount) maxCount = v; }));

    const rendered = grid.map(row =>
      Array.from(row).map(v => {
        if (v === 0) return ' ';
        const t = v / maxCount;
        if (t < 0.15) return '·';
        if (t < 0.4)  return '+';
        if (t < 0.7)  return '▪';
        return '■';
      }).join('')
    ).join('\n');

    // Reverse geocode last point for a location label
    let locationLabel = '';
    try {
      const geo = await fetch(
        `https://nominatim.openstreetmap.org/reverse?lat=${cLat}&lon=${cLng}&format=json`,
        { headers: { 'Accept-Language': 'en' } }
      );
      const geoData = await geo.json();
      const a = geoData.address ?? {};
      locationLabel = a.neighbourhood || a.suburb || a.city_district || a.town || a.city || '';
      if (locationLabel && (a.city || a.town)) {
        const city = a.city || a.town;
        if (locationLabel !== city) locationLabel += ', ' + city;
      }
    } catch {}

    function makeTopBorder(label, cols) {
      const inner = label ? ' ' + label + ' ' : '';
      const used = 2 + inner.length;
      const right = Math.max(0, cols - used);
      return '┌─' + inner + '─'.repeat(right) + '┐';
    }

    const bar = '─'.repeat(COLS);
    const boxed = makeTopBorder(locationLabel, COLS) + '\n'
      + rendered.split('\n').map(r => '│' + r + '│').join('\n')
      + '\n└' + bar + '┘';

    statusEl.remove();
    const out = document.createElement('div');
    out.className = 'term-line mid';
    out.style.cssText = 'white-space:pre;line-height:1.35;font-size:11px;';
    out.textContent = boxed;
    scrollEl.appendChild(out);

    const meta = document.createElement('div');
    meta.className = 'term-line dim';
    meta.textContent = lines.length + ' routes · last known location · ' + COLS + '×' + ROWS;
    scrollEl.appendChild(meta);

    appendLinks([{ label: 'open full map', href: '/heatmap' }]);

    appendSpacer();
    scrollBottom();
  } catch(err) {
    statusEl.textContent = 'error: could not load route data';
    appendSpacer();
    scrollBottom();
  }
}

// ---------- inline photo ----------
function appendInlinePhoto(entry) {
  const wrap = document.createElement('div');
  wrap.className = 'photo-inline';
  const img = document.createElement('img');
  img.src = entry.full;
  img.alt = entry.name;
  const cap = document.createElement('div');
