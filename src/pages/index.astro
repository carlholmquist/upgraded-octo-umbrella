---
import DarkLayout from "../layouts/DarkLayout.astro";
import { siteConfig } from "../config";

const nav = [
  { index: "001", label: "About", url: "/about" },
  { index: "002", label: "Photography", url: "/photography" },
  { index: "003", label: "Bookmarks", url: "/bookmarks" },
];
---

<DarkLayout title="Carl Holmquist" showClock centerMain>
  <span slot="header-left">Carl Holmquist</span>
  <span slot="footer-left">holmquist.studio</span>
  <a slot="footer-right" href={`mailto:${siteConfig.social.email}`} class="dark-link">{siteConfig.social.email}</a>

  <div class="info">
    <p class="info-title">{siteConfig.title}</p>
    <p class="info-bio">{siteConfig.info}</p>
  </div>

  <nav class="link-list">
      {nav.map(({ index, label, url }) => (
        <a href={url} class="nav-link">
          <span class="nav-index">{index}</span>
          <span class="nav-label">{label}</span>
        </a>
      ))}
  </nav>
</DarkLayout>

<style>
  .info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.05em;
  }

  .info-bio {
    font-size: 100%;
    font-weight: 300;
    color: var(--text);
    line-height: 1.8;
  }

  .link-list {
    columns: 3;
    column-gap: 32px;
    column-fill: auto;
    height: 280px;
  }

  @media (max-width: 520px) {
    .link-list { columns: 2; height: 390px; }
  }
</style>
