---
import "../styles/global.css";

const categories: { name: string; items: { label: string; url: string }[] }[] = [
  {
    name: "News",
    items: [
      {
        label: "DN",
        url: "https://www.dn.se",
      },
    ],
  },
  {
    name: "Google",
    items: [
      {
        label: "Google",
        url: "https://www.google.com",
      }
      {
        label: "Gmail",
        url: "https://mail.google.com",
      }
    ],
  },
  {
    name: "Engineering",
    items: [
      {
        label: "NCEES",
        url: "https://account.ncees.org/login",
      },
      {
        label: "SkyCiv",
        url: "https://platform.skyciv.com/login"
      },
      {
        label: "Free resources for FE",
        url: "https://journey2pe.com/the-ultimate-free-resource-guide-to-passing-the-fe-exam/",
      }
    ],
  },
  {
    name: "Web Apps",
    items: [
      {
        label: "Strudel",
        url: "https://strudel.cc",
      },
      {
        label: "Claude",
        url: "https://claude.ai",
      },
      {
        label: "ARC FLUIDS",
        url: "https://prosperousuniverse.com/auth/login?od=https://apex.prosperousuniverse.com/#/cards/c339a71756d1f504ac9cea23444aa725",
      },
    ],
  },
  {
    name: "Subscriptions",
    items: [],
  },
  {
    name: "Socials",
    items: [],
  },
  {
    name: "Developer",
    items: [],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>Carl Holmquist</title>
  </head>
  <body class="bg-white text-gray-800 min-h-screen">
    <div class="mx-auto max-w-3xl px-6 py-16 lg:px-8">

      <!-- Time & Date -->
      <header class="mb-10">
        <p id="clock" class="text-4xl font-bold text-gray-900 tabular-nums">--:--</p>
        <p id="date" class="text-sm text-gray-400 mt-1"></p>
      </header>

      <!-- Search -->
      <form
        action="https://www.google.com/search"
        method="get"
        class="mb-12"
      >
        <div class="flex items-center border border-gray-200 rounded-sm overflow-hidden focus-within:border-gray-400 transition-colors">
          <input
            type="text"
            name="q"
            placeholder="Search Google..."
            autocomplete="off"
            class="flex-1 px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 outline-none bg-white"
          />
          <button
            type="submit"
            class="px-4 py-2.5 text-gray-400 hover:text-gray-700 transition-colors text-sm"
            aria-label="Search"
          >
            ↵
          </button>
        </div>
      </form>

      <!-- Link Categories -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-10">
        {categories.map((cat) => (
          <section>
            <h2 class="text-xs text-gray-400 uppercase tracking-widest mb-3">{cat.name}</h2>
            {cat.items.length > 0 ? (
              <ul class="space-y-2">
                {cat.items.map((item) => (
                  <li>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-gray-700 underline underline-offset-2 hover:text-gray-900 transition-colors"
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-xs text-gray-300 italic">No links yet</p>
            )}
          </section>
        ))}
      </div>

      <footer class="mt-16 pt-4 border-t border-gray-100 flex items-center justify-between">
        <p class="text-xs text-gray-400">© {new Date().getFullYear()} Carl Holmquist</p>
        <nav class="flex gap-x-5">
          <a href="/portfolio" class="text-xs text-gray-400 hover:text-gray-700 transition-colors">Portfolio</a>
          <a href="/photography" class="text-xs text-gray-400 hover:text-gray-700 transition-colors">Photography</a>
        </nav>
      </footer>

    </div>

    <script>
      function updateClock() {
        const now = new Date();

        const time = now.toLocaleTimeString("en-US", {
          hour: "2-digit",
          minute: "2-digit",
          hour12: true,
        });

        const date = now.toLocaleDateString("en-US", {
          weekday: "long",
          month: "long",
          day: "numeric",
          year: "numeric",
        });

        const clockEl = document.getElementById("clock");
        const dateEl = document.getElementById("date");
        if (clockEl) clockEl.textContent = time;
        if (dateEl) dateEl.textContent = date;
      }

      updateClock();
      setInterval(updateClock, 1000);
    </script>
  </body>
</html>
