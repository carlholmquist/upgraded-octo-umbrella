---
import DarkLayout from "../layouts/DarkLayout.astro";
import rawPhotos from "../data/photos.json";
import { siteConfig } from "../config";

const cloudName = "drey6ump8";
function photoName(path: string) {
  const base = (path.split('/').pop() ?? path).replace(/\.[^.]+$/, '');
  return base.replace(/_[a-z0-9]{6}$/, '');
}
function photoYear(path: string) {
  const m = path.match(/20\d\d/);
  return m ? m[0] : '—';
}
const aboutData = {
  aboutMe: siteConfig.aboutMe,
  skills: siteConfig.skills,
  experience: siteConfig.experience,
  education: siteConfig.education,
  projects: siteConfig.projects,
  social: siteConfig.social,
};

const terminalData = siteConfig.terminal;

const bookmarksData = siteConfig.Bookmarks.flatMap(cat =>
  (cat.links ?? []).map(link => ({
    label: link.label,
    url: link.url,
    category: cat.catname,
  }))
);

const photosData = (rawPhotos as string[]).map(path => ({
  name: photoName(path),
  year: photoYear(path),
  full: `https://res.cloudinary.com/${cloudName}/image/upload/q_auto,f_auto,w_1800/${path}`,
}));
---

<DarkLayout title="Carl Holmquist" showClock>
  <span slot="header-left">Carl Holmquist</span>
  <span slot="footer-left" id="foot-left">~</span>
  <span slot="footer-right"><span class="hint-desktop">TAB COMPLETE · ↑ HISTORY · </span><span id="help-btn" style="color: var(--text-mid); cursor: pointer;">HELP</span></span>

  <div id="term">
    <div id="scrollback"></div>
    <div class="prompt-row" id="prompt-live">
      <span class="prompt">
        <span class="user">carl</span><span class="at"> @ studio </span><span id="prompt-home" class="cwd cwd-home">~</span><span id="prompt-cwd-rest" class="cwd"></span><span class="dollar"> $ </span>
      </span>
      <span class="input-wrap"><span id="term-ghost" class="ghost"></span><span id="hint-enter" class="hint-enter">&nbsp;(hit enter)</span><input id="term-input" class="hidden-input" type="text" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off" /></span>
    </div>
  </div>

  <script type="application/json" id="about-data" set:html={JSON.stringify(aboutData)} />
  <script type="application/json" id="photos-data" set:html={JSON.stringify(photosData)} />
  <script type="application/json" id="bookmarks-data" set:html={JSON.stringify(bookmarksData)} />
  <script type="application/json" id="terminal-data" set:html={JSON.stringify(terminalData)} />
</DarkLayout>

<style>
  :global(main) {
    max-width: 880px;
    padding-top: calc(var(--header-h) + 40px);
    padding-bottom: calc(var(--footer-h) + 32px);
  }

  /* term */
  #term { display: flex; flex-direction: column; gap: 2px; min-height: 60vh; }

  :global(.term-line) { white-space: pre-wrap; word-break: break-word; }
  :global(.term-line.dim) { color: var(--text-dim); }
  :global(.term-line.mid) { color: var(--text-mid); }
  :global(.cat-bullet) { padding-left: 2ch; text-indent: -2ch; white-space: pre-wrap; word-break: break-word; }
  :global(.cat-title) {
    display: inline-block; font-size: 13px !important; line-height: inherit; letter-spacing: 0.04em; margin-bottom: 6px;
    background: var(--text); color: var(--bg); padding: 0 4px;
    box-shadow: 0 0 8px var(--text-mid), 0 0 20px var(--text-dim);
    text-shadow: 0 0 4px var(--text-dim);
  }

  :global(.prompt-row) { display: flex; gap: 6px; align-items: baseline; color: var(--text-mid); }
  :global(.prompt) { flex: 0 0 auto; color: var(--text-dim); }
  :global(.prompt .user) { color: var(--text-mid); }
  :global(.prompt .cwd)  { color: var(--text); }
  :global(.prompt .cwd-home) { cursor: pointer; }
  :global(.prompt .cwd-home:hover) { text-decoration: underline; }
  :global(.prompt .at), :global(.prompt .dollar) { color: var(--text-dim); }
  :global(.echo-cmd) { color: var(--text); }
  :global(.echo-arg) {
    background: var(--text); color: var(--bg); padding: 0 4px;
    box-shadow: 0 0 8px var(--text-mid), 0 0 20px var(--text-dim);
    text-shadow: 0 0 4px var(--text-dim);
  }

  :global(.input-wrap) { flex: 1; position: relative; display: inline-block; min-height: 22px; }
  :global(.ghost) { color: var(--text); white-space: pre; }
  :global(.ghost::after) {
    content: '';
    display: inline-block; width: 8px; height: 14px;
    background: var(--text); vertical-align: -2px;
    animation: blink 1.05s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  :global(.hint-enter) { color: var(--text-dim); font-style: italic; pointer-events: none; }

  :global(.hidden-input) {
    position: absolute; inset: 0; opacity: 0; width: 100%; height: 100%;
    border: 0; background: transparent; color: transparent; caret-color: transparent;
    font: inherit; padding: 0; outline: none;
    font-size: 16px; /* prevent iOS zoom */
  }

  /* ls — long */
  :global(.ls-block) { margin: 6px 0; }
  :global(.ls-row) {
    display: grid;
    grid-template-columns: 100px 26px 36px 70px 100px 1fr;
    gap: 14px; padding: 0 6px; border-radius: 2px;
    color: var(--text-mid); white-space: nowrap; cursor: pointer;
  }
  :global(a.ls-row) { text-decoration: none; }
  :global(.ls-row .name) { color: var(--text); }
  :global(.ls-row.type-dir .name::after) { content: '/'; color: var(--text-dim); }
  :global(.ls-row.is-hidden .name) { color: var(--text-mid); }
  :global(.ls-row:hover) { background: var(--text); color: var(--bg); box-shadow: 0 0 8px var(--text-mid), 0 0 20px var(--text-dim); }
  :global(.ls-row:hover .name), :global(.ls-row:hover span) { color: var(--bg); }
  :global(.ls-row:hover), :global(.ls-row:hover span) {
    text-shadow: 0 0 4px var(--text-dim);
  }

  /* ls — compact */
  :global(.ls-compact) { display: flex; flex-wrap: wrap; gap: 0 28px; row-gap: 4px; }
  :global(.ls-compact .item) { cursor: pointer; color: var(--text); }
  :global(.ls-compact .item.dir::after) { content: '/'; color: var(--text-dim); }
  :global(.ls-compact .item.hidden) { color: var(--text-mid); }
  :global(.ls-compact .item:hover) { background: var(--text); color: var(--bg); }

  /* ls — numbered nav */
  :global(.ls-nav) { display: flex; flex-direction: column; gap: 2px; }
  :global(.ls-nav-row) {
    display: flex; align-items: baseline; gap: 18px;
    padding: 6px 6px; border-radius: 2px; cursor: pointer;
  }
  :global(.ls-nav-idx) { color: var(--text-dim); width: 38px; font-size: 11px; letter-spacing: 0.1em; }
  :global(.ls-nav-name) {
    color: var(--text); font-size: 17px; line-height: 24px;
    font-weight: 300; letter-spacing: -0.005em;
  }
  :global(.ls-nav-row.is-hidden .ls-nav-name) { color: var(--text-mid); }
  :global(.ls-nav-row:hover) { background: var(--text); }
  :global(.ls-nav-row:hover .ls-nav-idx) { color: var(--bg); opacity: 0.7; }
  :global(.ls-nav-row:hover .ls-nav-name) { color: var(--bg); }


  /* inline photo */
  :global(.photo-inline) { margin: 8px 0; max-width: 640px; }
  :global(.photo-inline img) { width: 100%; height: auto; display: block; border: 1px solid var(--rule); }
  :global(.photo-cap) { margin-top: 4px; }


  @media (max-width: 640px) {
    /* Tighter horizontal padding */
    :global(main) { padding-left: 12px; padding-right: 12px; }
    :global(body) { overflow-x: hidden; }

    /* Shorter prompt: hide "carl @ studio" */
    :global(.prompt .user), :global(.prompt .at) { display: none; }

    /* Allow prompt row to wrap if cwd is long */
    :global(.prompt-row) { flex-wrap: wrap; }

    /* ls-row: collapse to year + name only */
    :global(div.ls-row) { grid-template-columns: 48px 1fr; gap: 8px; }
    :global(div.ls-row span:nth-child(1)),
    :global(div.ls-row span:nth-child(2)),
    :global(div.ls-row span:nth-child(3)),
    :global(div.ls-row span:nth-child(4)) { display: none; }

    /* Search rows override inline grid: hide perms, show domain + title */
    :global(a.ls-row) { grid-template-columns: 1fr !important; gap: 8px; }
    :global(a.ls-row span:nth-child(1)),
    :global(a.ls-row span:nth-child(2)),
    :global(a.ls-row span:nth-child(3)),
    :global(a.ls-row span:nth-child(4)),
    :global(a.ls-row span:nth-child(5)) { display: none; }

    /* Photos full width */
    :global(.photo-inline) { max-width: 100%; }

/* Footer: hide long hint text on small screens */
    :global(.hint-desktop) { display: none; }
  }
</style>

<script is:inline>
(function () {

// ---------- data ----------
const ABOUT    = JSON.parse(document.getElementById('about-data').textContent);
const TERMINAL = JSON.parse(document.getElementById('terminal-data').textContent);

// ---------- about sub-files (built from config) ----------
const ABOUT_FILES = (() => {
  const a = ABOUT;
  const slug = s => s.toLowerCase()
    .replace(/[åäö]/g, c => ({å:'a',ä:'a',ö:'o'}[c]||c))
    .replace(/[^a-z0-9]+/g, '-').replace(/-$/, '');
  const files = [];
  files.push({ name: 'bio', type: 'file', hidden: false,
    perms: '-rw-r--r--', size: '—', year: '—', cat: a.aboutMe });
  if (a.skills?.length) files.push({ name: 'skills', type: 'file', hidden: false,
    perms: '-rw-r--r--', size: '—', year: '—', cat: a.skills.join('\n') });
  a.experience?.forEach(e => files.push({ name: slug(e.company), type: 'file', hidden: e.hidden ?? false,
    perms: '-rw-r--r--', size: '—', year: e.dateRange.split(/[–-]/)[0].trim(),
    cat: e.title + '  ·  ' + e.dateRange + '\n\n' + e.bullets.map(b => '  · ' + b).join('\n') }));
  a.education?.forEach(e => files.push({ name: slug(e.school), type: 'file', hidden: e.hidden ?? false,
    perms: '-rw-r--r--', size: '—', year: e.dateRange.split(/[–-]/)[0].trim(),
    cat: e.degree + '  ·  ' + e.dateRange + (e.achievements?.length ? '\n\n' + e.achievements.map(a => '  · ' + a).join('\n') : '') }));
  const links = [
    a.social?.email    && { label: 'email',    href: 'mailto:' + a.social.email },
    a.social?.linkedin && { label: 'linkedin', href: a.social.linkedin },
    a.social?.github   && { label: 'github',   href: a.social.github },
  ].filter(Boolean);
  if (links.length) files.push({ name: 'links', type: 'file', hidden: false,
    perms: '-rw-r--r--', size: '—', year: '—', links });
  return files;
})();

// ---------- project directories (built from config) ----------
const PROJECT_FILE_MAP = {};
const PROJECTS_CONFIG = ABOUT.projects ?? [];

PROJECTS_CONFIG.forEach(proj => {
  const slug = proj.slug || proj.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  const year = proj.year || '—';
  const files = [];
  files.push({ name: 'README', type: 'file', hidden: false, perms: '-rw-r--r--', size: '—', year, cat: proj.description });
  (proj.files ?? []).forEach(f => {
    let blocks;
    if (f.blocks) {
      blocks = f.blocks;
    } else {
      blocks = [{ content: f.content, bullets: f.bullets }];
    }
    files.push({ name: f.name, type: 'file', hidden: f.hidden ?? false, perms: '-rw-r--r--', size: '—', year: f.year ?? year, blocks });
  });
  const linkRows = proj.links?.length ? proj.links : (proj.link ? [{ label: proj.name, href: proj.link }] : []);
  if (linkRows.length) files.push({ name: 'links', type: 'file', hidden: false, perms: '-rw-r--r--', size: '—', year, links: linkRows });
  PROJECT_FILE_MAP[slug] = files;
});

// ---------- filesystem ----------
const HOME = [
  {
    name: '.intro', type: 'file', hidden: true,
    perms: '-rw-r--r--', size: '0.3k', year: '2026',
    cat: TERMINAL.intro,
    links: [
      ABOUT.social?.email    && { label: 'email',    href: 'mailto:' + ABOUT.social.email },
      ABOUT.social?.linkedin && { label: 'linkedin', href: ABOUT.social.linkedin },
      ABOUT.social?.github   && { label: 'github',   href: ABOUT.social.github },
    ].filter(Boolean),
  },
  {
    name: 'README', type: 'file', hidden: false,
    perms: '-rw-r--r--', size: '0.2k', year: '2026',
    cat: TERMINAL.readme,
  },
  { name: 'about',       type: 'dir',  hidden: false, perms: 'drwxr-xr-x', size: '—', year: '—' },
  { name: 'photography', type: 'dir',  hidden: false, perms: 'drwxr-xr-x', size: '—', year: '2018–' },
  { name: 'bookmarks',   type: 'dir',  hidden: false, perms: 'drwxr-xr-x', size: '—', year: '—' },
  { name: 'heatmap',     type: 'dir',  hidden: false, perms: 'drwxr-xr-x', size: '—', year: '2025',
    ascii: 'https://studiobackend.onrender.com/geojson' },
  { name: 'projects',    type: 'dir',  hidden: false, perms: 'drwxr-xr-x', size: '—', year: '2022–' },
  {
    name: '.colophon', type: 'file', hidden: true,
    perms: '-rw-r--r--', size: '0.2k', year: '2026',
    cat: TERMINAL.colophon,
  },
];

const PROJECTS = [
  {
    name: 'README', type: 'file', hidden: false,
    perms: '-rw-r--r--', size: '0.4k', year: '2026',
    cat: "this is a small archive of things i've made.\nclick any directory to open it, or type `help`.\n`ls -a` shows the rest.",
  },
  ...PROJECTS_CONFIG.map(proj => ({
    name: proj.slug || proj.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''),
    type: 'dir', hidden: proj.hidden ?? false, perms: 'drwxr-xr-x', size: '—', year: proj.year || '—',
  })),
  {
    name: '.well-hidden', type: 'file', hidden: true,
    perms: '-rw-------', size: '0.0k', year: '????',
    cat: "you found it. there is nothing here. or maybe there is.",
  },
];

// ---------- bookmarks ----------
const BOOKMARKS = JSON.parse(document.getElementById('bookmarks-data').textContent).map(b => ({
  name: b.label,
  type: 'bookmark',
  hidden: false,
  perms: 'lrwxr-xr-x',
  size: '—',
  year: b.category,
  url: b.url,
}));

// ---------- photos ----------
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const PHOTOS = shuffle(JSON.parse(document.getElementById('photos-data').textContent).map(p => ({
  name: p.name, type: 'photo', hidden: false,
  perms: '-rw-r--r--', size: '—', year: p.year, full: p.full,
})));

// ---------- state ----------
let cwd = '~';
let history = [];
let histIdx = -1;
let firstCommand = true;
let prefillActive = true;

// ---------- dom refs ----------
const termEl    = document.getElementById('term');
const scrollEl  = document.getElementById('scrollback');
const inputEl   = document.getElementById('term-input');
const ghostEl   = document.getElementById('term-ghost');
const promptHomeEl = document.getElementById('prompt-home');
const promptRestEl = document.getElementById('prompt-cwd-rest');
const footLeft  = document.getElementById('foot-left');
const helpBtn   = document.getElementById('help-btn');

// ---------- utils ----------
function esc(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function listAt(path) {
  if (path === '~') return HOME;
  if (path === '~/about') return ABOUT_FILES;
  if (path === '~/projects') return PROJECTS;
  if (path.startsWith('~/projects/')) return PROJECT_FILE_MAP[path.slice('~/projects/'.length)] ?? [];
  if (path === '~/photography') return PHOTOS;
  if (path === '~/bookmarks') return BOOKMARKS;
  return [];
}

function findEntry(path, name) {
  return listAt(path).find(e => e.name === name);
}

function openFrom(fromPath, name) {
  const savedCwd = cwd;
  cwd = fromPath;
  openName(name);
  if (cwd === fromPath) cwd = savedCwd;
}

function visible(entries, showHidden) {
  return entries.filter(e => showHidden || !e.hidden);
}

function asciiTree(cwdPath) {
  if (cwdPath === '~') return [
    "~",
    "├── README",
    "├── about/",
    "│   ├── bio",
    "│   ├── skills",
    "│   └── links",
    "├── photography/",
    "├── bookmarks/",
    "├── heatmap →",
    "├── projects/",
    "│   ├── ghost/",
    "│   ├── wood/",
    "│   └── things/",
    "└── (2 hidden)",
  ].join('\n');
  if (cwdPath === '~/projects') return [
    "~/projects",
    "├── README",
    "├── ghost/",
    "│   ├── README · why · how · links",
    "├── wood/",
    "│   ├── README · thesis · result · links",
    "├── things/",
    "│   ├── README · inventory · notes",
    "└── (1 hidden)",
  ].join('\n');
  return listAt(cwdPath).filter(e => !e.hidden)
    .map((e, i, a) => (i === a.length - 1 ? '└── ' : '├── ') + e.name + (e.type === 'dir' ? '/' : ''))
    .join('\n');
}

function resolvePath(from, rel) {
  if (!rel || rel === '.' ) return from;
  if (rel === '~' || rel === '/') return '~';
  if (rel.startsWith('~/')) return rel.replace(/\/+$/, '') || '~';
  const parts = from.split('/');
  for (const seg of rel.replace(/\/+$/, '').split('/')) {
    if (!seg || seg === '.') continue;
    if (seg === '..') { if (parts.length > 1) parts.pop(); }
    else parts.push(seg);
  }
  return parts.join('/') || '~';
}

function scrollBottom() {
  const vv = window.visualViewport;
  const promptEl = document.getElementById('prompt-live');
  if (vv && promptEl && vv.height < window.innerHeight - 80) {
    // Keyboard is open — scroll so prompt sits just above it
    requestAnimationFrame(() => {
      const rect = promptEl.getBoundingClientRect();
      const visibleBottom = vv.offsetTop + vv.height;
      if (rect.bottom > visibleBottom - 8) {
        window.scrollBy({ top: rect.bottom - visibleBottom + 8, behavior: 'smooth' });
      }
    });
    return;
  }
  requestAnimationFrame(() => requestAnimationFrame(() => {
    const footerH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--footer-h')) || 50;
    const promptEl = document.getElementById('prompt-live');
    const promptBottom = promptEl.getBoundingClientRect().bottom + window.scrollY;
    window.scrollTo({ top: promptBottom - window.innerHeight + footerH + 16, behavior: 'smooth' });
  }));
}

function updateFooter() {
  if (footLeft) footLeft.textContent = cwd.toUpperCase();
  if (promptRestEl) promptRestEl.textContent = cwd === '~' ? '' : cwd.slice(1);
}

// ---------- command hint ----------
function cmdHint(r) {
  if (r.type === 'dir' && (r.embed || r.ascii)) return 'open';
  if (r.type === 'dir') return 'cd';
  if (r.type === 'file') return 'cat';
  if (r.type === 'link' || r.type === 'bookmark' || r.type === 'photo') return 'open';
  return 'open';
}

// ---------- dom builders ----------
function appendSpacer() {
  const d = document.createElement('div');
  d.style.height = '12px';
  scrollEl.appendChild(d);
}

function appendLine(cls, text) {
  const d = document.createElement('div');
  d.className = 'term-line' + (cls ? ' ' + cls : '');
  d.textContent = text;
  scrollEl.appendChild(d);
}

function appendCat(cls, text) {
  const lines = text.split('\n');
  const block = document.createElement('div');
  block.className = 'term-line' + (cls ? ' ' + cls : '');
  lines.forEach(line => {
    const span = document.createElement('div');
    if (/^  · /.test(line)) {
      span.className = 'cat-bullet';
      span.textContent = line.trimStart();
    } else if (line === '') {
      span.innerHTML = '&nbsp;';
    } else {
      span.textContent = line;
    }
    block.appendChild(span);
  });
  scrollEl.appendChild(block);
}

function appendBlocks(blocks) {
  const wrap = document.createElement('div');
  wrap.className = 'term-line mid';
  blocks.forEach((b, i) => {
    if (i > 0) {
      const gap = document.createElement('div');
      gap.innerHTML = '&nbsp;';
      wrap.appendChild(gap);
    }
    if (b.title) {
      const t = document.createElement('div');
      t.className = 'cat-title';
      t.textContent = b.title;
      wrap.appendChild(t);
    }
    if (b.content) {
      b.content.split('\n').forEach(line => {
        const d = document.createElement('div');
        if (line === '') { d.innerHTML = '&nbsp;'; } else { d.textContent = line; }
        wrap.appendChild(d);
      });
    }
    if (b.bullets?.length) {
      if (b.content) {
        const gap = document.createElement('div');
        gap.innerHTML = '&nbsp;';
        wrap.appendChild(gap);
      }
      b.bullets.forEach(bullet => {
        const d = document.createElement('div');
        d.className = 'cat-bullet';
        d.textContent = '· ' + bullet;
        wrap.appendChild(d);
      });
    }
    if (b.links?.length) {
      const linkBlock = document.createElement('div');
      linkBlock.className = 'ls-block';
      b.links.forEach(l => {
        const a = document.createElement('a');
        a.href = l.href; a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.className = 'ls-row type-link';
        a.innerHTML = `<span>lrwxr-xr-x</span><span>1</span><span>open</span><span>—</span><span>—</span><span class="name">${esc(l.label)} →</span>`;
        linkBlock.appendChild(a);
      });
      wrap.appendChild(linkBlock);
    }
    if (b.photo) {
      const photoWrap = document.createElement('div');
      photoWrap.className = 'photo-inline';
      const img = document.createElement('img');
      img.src = b.photo;
      img.alt = b.caption || '';
      img.loading = 'lazy';
      photoWrap.appendChild(img);
      if (b.caption) {
        const cap = document.createElement('div');
        cap.className = 'photo-cap term-line dim';
        cap.textContent = b.caption;
        photoWrap.appendChild(cap);
      }
      wrap.appendChild(photoWrap);
    }
  });
  scrollEl.appendChild(wrap);
}

function appendPromptEcho(cwdStr, cmd) {
  const row = document.createElement('div');
  row.className = 'prompt-row';
  const parts = cmd.split(/^(\S+)\s*/);
  const verb = parts[1] ?? cmd;
  const args = parts[2] ?? '';
  const cmdHtml = args
    ? esc(verb) + ' <span class="echo-arg">' + esc(args) + '</span>'
    : esc(verb);
  row.innerHTML =
    `<span class="prompt"><span class="user">carl</span><span class="at"> @ studio </span><span class="cwd">${esc(cwdStr)}</span><span class="dollar"> $ </span></span>` +
    `<span class="echo-cmd">${cmdHtml}</span>`;
  scrollEl.appendChild(row);
  return row;
}

function scrollToEl(el) {
  const imgs = [...scrollEl.querySelectorAll('img')].filter(img => !img.complete);
  const settle = imgs.length
    ? Promise.all(imgs.map(img => new Promise(r => { img.addEventListener('load', r, { once: true }); img.addEventListener('error', r, { once: true }); })))
    : Promise.resolve();
  settle.then(() => requestAnimationFrame(() => {
    const headerH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-h')) || 60;
    const top = el.getBoundingClientRect().top + window.scrollY - headerH - 16;
    window.scrollTo({ top, behavior: 'instant' });
  }));
}

function smartScroll(anchorEl) {
  const imgs = [...scrollEl.querySelectorAll('img')].filter(img => !img.complete);
  const settle = imgs.length
    ? Promise.all(imgs.map(img => new Promise(r => { img.addEventListener('load', r, { once: true }); img.addEventListener('error', r, { once: true }); })))
    : Promise.resolve();
  settle.then(() => requestAnimationFrame(() => {
    const style = getComputedStyle(document.documentElement);
    const headerH = parseInt(style.getPropertyValue('--header-h')) || 60;
    const footerH = parseInt(style.getPropertyValue('--footer-h')) || 50;
    const usableViewport = window.innerHeight - headerH - footerH;
    const anchorDocTop = anchorEl.getBoundingClientRect().top + window.scrollY;
    const contentHeight = document.body.scrollHeight - anchorDocTop;
    if (contentHeight > usableViewport * 0.75) {
      window.scrollTo({ top: anchorDocTop - headerH - 8, behavior: 'instant' });
    } else {
      scrollBottom();
    }
  }));
}

function appendLsLong(rows) {
  const renderPath = cwd;
  const block = document.createElement('div');
  block.className = 'ls-block';
  const total = document.createElement('div');
  total.className = 'term-line dim';
  total.textContent = 'total ' + rows.length;
  block.appendChild(total);
  rows.forEach(r => {
    const row = document.createElement('div');
    row.className = 'ls-row type-' + r.type + (r.hidden ? ' is-hidden' : '');
    row.title = 'open ' + r.name;
    let childCount = 1;
    if (r.type === 'dir') {
      const dirPath = renderPath === '~' ? '~/' + r.name : renderPath + '/' + r.name;
      childCount = visible(listAt(dirPath), false).length || 1;
    } else if (r.blocks) {
      const text = r.blocks.map(b => [b.title, b.content, ...(b.bullets ?? [])].filter(Boolean).join('\n')).join('\n');
      childCount = text.split('\n').filter(l => l.trim()).length || 1;
    } else if (r.cat) {
      childCount = r.cat.split('\n').filter(l => l.trim()).length || 1;
    }
    row.innerHTML =
      `<span>${esc(r.perms)}</span>` +
      `<span>${childCount}</span>` +
      `<span>${cmdHint(r)}</span>` +
      `<span>${esc(r.size)}</span>` +
      `<span>${esc(r.year)}</span>` +
      `<span class="name">${esc(r.name)}${r.type === 'link' ? ' →' : ''}</span>`;
    row.addEventListener('click', () => openFrom(renderPath, r.name));
    block.appendChild(row);
  });
  scrollEl.appendChild(block);
}

function appendLsCompact(rows) {
  const renderPath = cwd;
  const block = document.createElement('div');
  block.className = 'ls-block';
  const wrap = document.createElement('div');
  wrap.className = 'ls-compact';
  rows.forEach(r => {
    const span = document.createElement('span');
    span.className = 'item' + (r.type === 'dir' ? ' dir' : '') + (r.hidden ? ' hidden' : '');
    span.textContent = r.name + (r.type === 'link' ? ' →' : '');
    span.addEventListener('click', () => openFrom(renderPath, r.name));
    wrap.appendChild(span);
  });
  block.appendChild(wrap);
  scrollEl.appendChild(block);
}

function appendLsNav(rows) {
  const renderPath = cwd;
  const block = document.createElement('div');
  block.className = 'ls-block';
  const nav = document.createElement('div');
  nav.className = 'ls-nav';
  rows.forEach((r, i) => {
    const row = document.createElement('div');
    row.className = 'ls-nav-row type-' + r.type + (r.hidden ? ' is-hidden' : '');
    row.innerHTML =
      `<span class="ls-nav-idx">${String(i + 1).padStart(3, '0')}</span>` +
      `<span class="ls-nav-name">${esc(r.name)}${r.type === 'dir' ? '/' : ''}${r.type === 'link' ? ' →' : ''}</span>`;
    row.addEventListener('click', () => openFrom(renderPath, r.name));
    nav.appendChild(row);
  });
  block.appendChild(nav);
  scrollEl.appendChild(block);
}

function appendLs(rows, mode) {
  if (mode === 'long') appendLsLong(rows);
  else if (mode === 'compact') appendLsCompact(rows);
  else if (mode === 'nav') appendLsNav(rows);
  else appendLsLong(rows);
}

const PHOTO_PAGE = 10;

function appendPhotoGallery(rows, startIdx = 0) {
  const block = document.createElement('div');
  block.className = 'ls-block photo-gallery';

  if (startIdx === 0) {
    const total = document.createElement('div');
    total.className = 'term-line dim';
    total.textContent = 'total ' + rows.length;
    block.appendChild(total);
  }

  const page = rows.slice(startIdx, startIdx + PHOTO_PAGE);
  page.forEach(r => {
    const row = document.createElement('div');
    row.className = 'ls-row type-photo';
    row.innerHTML =
      `<span>${esc(r.perms)}</span><span>1</span><span>open</span>` +
      `<span>${esc(r.size)}</span><span>${esc(r.year)}</span>` +
      `<span class="name">${esc(r.name)}</span>`;
    block.appendChild(row);
    const wrap = document.createElement('div');
    wrap.className = 'photo-inline';
    const img = document.createElement('img');
    img.src = r.full;
    img.alt = r.name;
    img.loading = 'lazy';
    wrap.appendChild(img);
    block.appendChild(wrap);
  });

  const nextIdx = startIdx + PHOTO_PAGE;
  if (nextIdx < rows.length) {
    const remaining = rows.length - nextIdx;
    const loadMore = document.createElement('div');
    loadMore.className = 'ls-row type-link load-more';
    loadMore.innerHTML =
      `<span>-rw-r--r--</span><span>·</span><span>·</span>` +
      `<span>·</span><span>·</span><span class="name">load ${Math.min(PHOTO_PAGE, remaining)} more →</span>`;
    loadMore.addEventListener('click', () => {
      loadMore.remove();
      appendPhotoGallery(rows, nextIdx);
      scrollBottom();
    });
    block.appendChild(loadMore);
  }

  scrollEl.appendChild(block);
}

function appendBookmarkList(rows) {
  const block = document.createElement('div');
  block.className = 'ls-block';
  const total = document.createElement('div');
  total.className = 'term-line dim';
  total.textContent = 'total ' + rows.length;
  block.appendChild(total);
